# Telegram Bot
BOT_TOKEN=your_token_here
ALLOWED_USERS=123456789,987654321
ADMIN_IDS=123456789
BOT_URL=https://t.me/your_bot_name

# bePaid (bepaid.by) — для оплаты из Беларуси/СНГ
BEPAID_SHOP_ID=your_shop_id
BEPAID_SECRET_KEY=your_secret_key
BEPAID_WEBHOOK_URL=https://your-domain.com   # URL сервера, куда bePaid шлёт вебхук

# PostgreSQL (автоматически подставляется в docker-compose)
POSTGRES_PASSWORD=your_strong_password_here

# Webhook server port (для bePaid)
WEBHOOK_PORT=8444
